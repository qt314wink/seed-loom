{
  "name": "seed-loom",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "filters:check": "npm --prefix packages/svg-filter-atlas run check",
    "check": "npm run filters:check && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@melodicbloom/svg-filter-atlas": "file:packages/svg-filter-atlas"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
